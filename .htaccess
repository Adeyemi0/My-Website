RewriteEngine On

# ── 1. Force HTTPS + remove www (combine for efficiency) ──────────────────
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\.adediranadeyemi\.com$ [NC]
RewriteRule ^ https://adediranadeyemi.com%{REQUEST_URI} [L,R=301]

# ── 2. Remove .html extension from URLs ───────────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# ── 3. Optional: Redirect .html to clean URL (canonical SEO fix) ───────────
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ %1 [L,R=301]
