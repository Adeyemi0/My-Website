
# ── 1. HTTPS redirect (http → https) ──────────────────────────────────────
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── 2. www → non-www redirect ─────────────────────────────────────────────
RewriteCond %{HTTP_HOST} ^www\.adediranadeyemi\.com$ [NC]
RewriteRule ^ https://adediranadeyemi.com%{REQUEST_URI} [L,R=301]

# ── 3. Remove .html extension from URLs ───────────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [L]

# ── 4. Canonical trailing slash on homepage ────────────────────────────────
RewriteCond %{REQUEST_URI} ^/$
RewriteRule ^ https://adediranadeyemi.com/ [L,R=301]
